{
  "name": "graduation-invitation",
  "description": "A beautiful and modern graduation ceremony invitation website. \"My memories, with you.\" Thank you for being part of this journey.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leecois/graduation.git"
  },
  "homepage": "https://graduation.khanh.me",
  "keywords": [
    "graduation",
    "invitation",
    "website"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https",
    "build": "node ./styles/scripts/setup-styles.ts && next build",
    "start": "next start",
    "lint": "biome lint --max-diagnostics=200",
    "lint:fix": "biome lint --write --max-diagnostics=200",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit --incremental false",
    "setup:styles": "bun ./styles/scripts/setup-styles.ts"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "gsap": "^3.13.0",
    "hamo": "1.0.0-dev.6",
    "lenis": "^1.3.13",
    "next": "16.0.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tempus": "1.0.0-dev.15"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.3",
    "@csstools/postcss-global-data": "^3.1.0",
    "@next/bundle-analyzer": "16.0.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.16",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.10.0",
    "@types/react": "19.2.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "postcss-functions": "^4.0.2",
    "postcss-preset-env": "^10.4.0",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@tailwindcss/oxide",
    "esbuild",
    "sharp"
  ],
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=20"
  }
}
